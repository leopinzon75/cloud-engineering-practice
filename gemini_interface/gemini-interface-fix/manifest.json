{
  "manifest_version": 3,
  "name": "Gemini Run Button Fixer",
  "version": "1.0",
  "description": "Fuerza la visibilidad de los elementos interactivos y botones en Gemini.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}